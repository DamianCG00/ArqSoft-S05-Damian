@model Citas_app.Models.Paciente

@{
    ViewData["Title"] = "Detalle del Paciente";
}

<h2>Perfil del Paciente</h2>
<hr />

<div class="card p-3 shadow-sm">
    <dl class="row mb-0">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Apellido (Ref)</dt>
        <dd class="col-sm-9">@Model.Apellido</dd>

        <dt class="col-sm-3">Email (Ref)</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Teléfono (Ref)</dt>
        <dd class="col-sm-9">@Model.Telefono</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-controller="Cita" asp-action="PorPaciente" asp-route-pacienteId="@Model.Id.ToString()" class="btn btn-primary">Ver sus Citas</a>
    <a asp-action="Index" class="btn btn-secondary">Volver al Directorio</a>
</div>