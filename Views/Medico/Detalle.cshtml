@model CitasApp.Models.Medico

@{
    ViewData["Title"] = "Detalle del Médico";
}

<h2>Expediente Médico</h2>
<hr />

<div class="card p-3 shadow-sm">
    <dl class="row mb-0">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">Dr(a). @Model.Nombre</dd>

        <dt class="col-sm-3">Apellido (Ref)</dt>
        <dd class="col-sm-9">@Model.Apellido</dd>

        <dt class="col-sm-3">Especialidad (Ref)</dt>
        <dd class="col-sm-9">@Model.Especialidad</dd>

        <dt class="col-sm-3">Número de Licencia</dt>
        <dd class="col-sm-9">@Model.NumeroLicencia</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Directorio</a>
</div>