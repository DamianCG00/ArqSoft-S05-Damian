@model IEnumerable<CitasApp.Models.Cita>

@{
    ViewData["Title"] = "Agenda de Citas";
}

<h2>Agenda Completa de Citas</h2>

<p style="margin-top: 15px; margin-bottom: 20px;">
    <a asp-action="Crear" class="btn btn-primary fw-bold"> + Agregar Nueva Cita</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Fecha y Hora</th>
            <th>Paciente</th>
            <th>Médico</th>
            <th>Motivo (Ref)</th>
            <th>Estado (Ref)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Fecha a las @item.Hora</td>
                <td>
                    @(ViewBag.NombresPacientes != null && ViewBag.NombresPacientes.ContainsKey(item.PacienteId.ToString()) 
                        ? ViewBag.NombresPacientes[item.PacienteId.ToString()] 
                        : "Paciente Desconocido")
                </td>
                <td>
                    @(ViewBag.NombresMedicos != null && ViewBag.NombresMedicos.ContainsKey(item.MedicoId.ToString()) 
                        ? ViewBag.NombresMedicos[item.MedicoId.ToString()] 
                        : "Médico Desconocido")
                </td>
                <td>@item.Motivo</td>
                <td>@item.Estado</td>
            </tr>
        }
    </tbody>
</table>